{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/quality-before-commit.sh", "timeout": 120 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/block-sensitive-files.sh" },
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/plan-phase-write-block.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/format-after-edit.sh", "timeout": 15 },
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/run-tests-after-edit.sh", "timeout": 30 }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/notify-on-block.sh", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/stop-quality-check.sh", "timeout": 10 }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/verify-before-task-complete.sh", "timeout": 300 }
        ]
      }
    ]
  }
}
